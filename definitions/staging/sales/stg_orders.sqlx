config {
  type: "view",
  schema: "sentinel_staging",
  assertions: {
    uniqueKey: ["order_id"],      
    nonNull: ["order_id", "amount", "product_id"], 
    rowConditions: [
      "amount >= 0",              
      "order_date <= CURRENT_DATE()"
    ]
  }
}

SELECT
  order_id,
  customer_name,
  SAFE_CAST(amount AS FLOAT64) AS amount,
  status,
  SAFE.PARSE_DATE('%Y-%m-%d', order_date) AS order_date,
  email,
  product_id,
  warehouse_id,
  batch_date,
  processed_dttm
FROM
  ${ref("orders_raw")}
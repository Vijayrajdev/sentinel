config {
  type: "assertion",
  tags: ["sales", "orders", "sla"],
  description: "Validates freshness and completeness SLAs as defined in the Data Contract."
}

SELECT
  'Freshness Breach: Max processed_dttm is older than 24 hours' AS failure_reason,
  MAX(processed_dttm) AS last_processed_at
FROM ${ref("fct_orders")}
HAVING MAX(processed_dttm) < TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 24 HOUR)
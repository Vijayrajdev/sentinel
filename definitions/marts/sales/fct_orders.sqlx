config {
  type: "incremental",
  schema: "sentinel_marts",
  uniqueKey: ["order_id"],
  bigquery: {
    partitionBy: "batch_date",
    clusterBy: ["status", "warehouse_id"]
  },
  tags: ["sales", "orders", "marts"],
  assertions: {
    nonNull: ["order_id", "customer_name", "amount", "batch_date", "processed_dttm"],
    uniqueKey: ["order_id"],
    rowConditions: [
      "amount >= 0",
      "amount <= 1000000",
      "status IN ('PENDING', 'SHIPPED', 'DELIVERED', 'CANCELLED', 'RETURNED')",
      "REGEXP_CONTAINS(order_id, r"^ORD-[0-9]{5,10}$")"
    ]
  }
}

SELECT
  order_id,
  customer_name,
  amount,
  status,
  order_date,
  email,
  product_id,
  warehouse_id,
  CURRENT_DATE() AS batch_date,
  processed_dttm AS updated_at
FROM
  ${ref("stg_orders")}

-- This block ensures idempotency by only fetching new records
${when(incremental(), `WHERE processed_dttm > (SELECT MAX(updated_at) FROM ${self()})` )}
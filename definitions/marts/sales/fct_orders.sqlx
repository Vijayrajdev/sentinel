config {
  type: "incremental",
  schema: "sentinel_marts",
  uniqueKey: ["order_id"],
  bigquery: {
    partitionBy: "order_date",
    clusterBy: ["status", "warehouse_id", "product_id"]
  },
  tags: ["sales", "orders", "marts"],
  assertions: {
    uniqueKey: ["order_id"],
    nonNull: ["order_id"]
  }
}

SELECT
  order_id,
  customer_name,
  amount,
  status,
  order_date,
  email,
  product_id,
  warehouse_id,
  processed_dttm AS updated_at
FROM
  ${ref("stg_orders")}

-- This block ensures idempotency by only fetching new records
${when(incremental(), `WHERE processed_dttm > (SELECT MAX(updated_at) FROM ${self()})` )}
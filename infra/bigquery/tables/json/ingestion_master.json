[
  {
    "name": "file_pattern",
    "mode": "REQUIRED",
    "type": "STRING",
    "description": "Regex pattern to match incoming files (e.g., '^sales_.*\\.csv$')",
    "fields": []
  },
  {
    "name": "target_dataset",
    "mode": "REQUIRED",
    "type": "STRING",

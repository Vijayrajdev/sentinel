[
  {
    "name": "file_pattern",
    "mode": "REQUIRED",
    "type": "STRING",
    "description": "Regex pattern to match incoming files (e.g., '^sales_.*\\.csv$')"
  },
  {
    "name": "target_dataset",
    "mode": "REQUIRED",
    "type": "STRING",
    "description": "Destination BigQuery Dataset (e.g., 'sentinel_raw_landing')"
  },
  {
    "name": "target_table",
    "mode": "REQUIRED",
    "type": "STRING",
    "description": "Destination Table Name (e.g., 'raw_sales')"
  },
  {
    "name": "domain",
    "mode": "REQUIRED",
    "type": "STRING",
    "description": "The tables domain (e.g., 'Sales')"
  },
  {
    "name": "file_format",
    "mode": "NULLABLE",
    "type": "STRING",
    "description": "Expected format: CSV, JSON, AVRO, PARQUET, XLSX (Default: CSV)"
  },
  {
    "name": "delimiter",
    "mode": "NULLABLE",
    "type": "STRING",
    "description": "Field delimiter for CSVs (Default: ',')"
  },
  {
    "name": "quote_char",
    "mode": "NULLABLE",
    "type": "STRING",
    "description": "Quote character for CSVs (e.g., '\"')"
  },
  {
    "name": "skip_header_rows",
    "mode": "NULLABLE",
    "type": "INTEGER",
    "description": "Number of rows to skip (Default: 1)"
  },
  {
    "name": "landing_bucket",
    "mode": "NULLABLE",
    "type": "STRING",
    "description": "Specific source bucket to monitor (Optional)"
  },
  {
    "name": "archive_bucket",
    "mode": "NULLABLE",
    "type": "STRING",
    "description": "Specific destination archive bucket (Optional)"
  },
  {
    "name": "write_disposition",
    "mode": "NULLABLE",
    "type": "STRING",
    "description": "'WRITE_APPEND' (default) or 'WRITE_TRUNCATE'"
  },
  {
    "name": "is_active",
    "mode": "REQUIRED",
    "type": "BOOLEAN",
    "description": "Flag to enable/disable ingestion for this pattern"
  },
  {
    "name": "created_at",
    "mode": "NULLABLE",
    "type": "TIMESTAMP",
    "description": "When this rule was created"
  }
]
